# ============================================
# Logi-Track V2 - Configuration Environnement
# ============================================
# Copier ce fichier en .env et adapter les valeurs

# Base de données MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=logitrack2
DB_PORT=3306

# Serveur
PORT=3003
NODE_ENV=production

# JWT - IMPORTANT: Changer en production !
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY
JWT_EXPIRES_IN=24h

# CORS - Origines autorisées (séparées par des virgules)
# Adapter avec le domaine/IP réel du serveur
CORS_ORIGINS=http://localhost:3003

# Rate Limiting (requêtes par fenêtre)
RATE_LIMIT_AUTH=20
RATE_LIMIT_API=1000

# Socket.io
SOCKET_ENABLED=true

# Uploads
MAX_FILE_SIZE=10485760
